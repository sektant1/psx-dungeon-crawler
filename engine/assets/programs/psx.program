        param_named_auto ambientLight ambient_light_colour
        param_named_auto lightPos light_position_view_space_array 3
        param_named_auto lightDiffuse light_diffuse_colour_array 3
        param_named_auto lightAtten light_attenuation_array 3
        param_named_auto lightCount light_count
        param_named omniAttenuation float 1.0
        param_named perPixelLighting float 1.0
    }
}

fragment_program PSX_FS_UnlitTransparent glsl
{
    source psx.frag
    preprocessor_defines ALPHA_BLEND=1
    default_params
    {
        param_named albedoTex int 0
        param_named modulateColor float4 1.0 1.0 1.0 1.0
        param_named_auto fogColour fog_colour
        param_named_auto fogParams fog_params
        param_named_auto farClip far_clip_distance
    }
}

fragment_program PSX_FS_LitAlphaScissor glsl
{
    source psx.frag
    preprocessor_defines LIT=1,ALPHA_SCISSOR=1
    default_params
    {
        param_named albedoTex int 0
        param_named modulateColor float4 1.0 1.0 1.0 1.0
        param_named alphaScissor float 0.1
        param_named_auto fogColour fog_colour
        param_named_auto fogParams fog_params
        param_named_auto farClip far_clip_distance
        param_named_auto ambientLight ambient_light_colour
        param_named_auto lightPos light_position_view_space_array 3
        param_named_auto lightDiffuse light_diffuse_colour_array 3
        param_named_auto lightAtten light_attenuation_array 3
        param_named_auto lightCount light_count
        param_named omniAttenuation float 1.0
        param_named perPixelLighting float 1.0
    }
}

fragment_program PSX_FS_UnlitAlphaScissor glsl
{
    source psx.frag
    preprocessor_defines ALPHA_SCISSOR=1
    default_params
    {
        param_named albedoTex int 0
        param_named modulateColor float4 1.0 1.0 1.0 1.0
        param_named alphaScissor float 0.1
        param_named_auto fogColour fog_colour
        param_named_auto fogParams fog_params
        param_named_auto farClip far_clip_distance
    }
}

fragment_program PSX_FS_LitNoTex glsl
{
    source psx.frag
    preprocessor_defines LIT=1,NO_TEXTURE=1
    default_params
    {
        param_named modulateColor float4 1.0 1.0 1.0 1.0
        param_named_auto fogColour fog_colour
        param_named_auto fogParams fog_params
        param_named_auto farClip far_clip_distance
        param_named_auto ambientLight ambient_light_colour
        param_named_auto lightPos light_position_view_space_array 3
        param_named_auto lightDiffuse light_diffuse_colour_array 3
        param_named_auto lightAtten light_attenuation_array 3
        param_named_auto lightCount light_count
        param_named omniAttenuation float 1.0
        param_named perPixelLighting float 1.0
    }
}

fragment_program PSX_FS_LightVolume glsl
{
    source psx.frag
    preprocessor_defines LIT=1,NO_TEXTURE=1,LIGHT_VOLUME=1,BLEND_ADD=1
    default_params
    {
        param_named modulateColor float4 1.0 1.0 1.0 1.0
        // no fogColour: the BLEND_ADD fog path fades to black, so the GLSL
        // compiler eliminates that uniform
        // no farClip either: the BLEND_ADD path writes vec4(0), so the
        // compiler eliminates that uniform too
        param_named_auto fogParams fog_params
        param_named_auto ambientLight ambient_light_colour
        param_named_auto lightPos light_position_view_space_array 3
        param_named_auto lightDiffuse light_diffuse_colour_array 3
        param_named_auto lightAtten light_attenuation_array 3
        param_named_auto lightCount light_count
        param_named omniAttenuation float 1.0
        param_named perPixelLighting float 1.0
    }
}

// --------------------------------------------------------- post process ---

vertex_program Dither_VS glsl
{
    source quad.vert
    default_params
    {
        param_named_auto worldViewProj worldviewproj_matrix
    }
}

fragment_program Dither_FS glsl
{
    source dither.frag
    default_params
    {
        param_named sceneTex int 0
        param_named ditherTex int 1
        param_named colDepth float 15.0
        param_named ditherBanding float 1.0
    }
}

vertex_program Stylize_VS glsl
{
    source quad.vert
    default_params
    {
        param_named_auto worldViewProj worldviewproj_matrix
    }
}

fragment_program Stylize_FS glsl
{
    source pixel_stylize.frag
    default_params
    {
        param_named sceneTex int 0
        param_named normalDepthTex int 1
        param_named_auto farClip far_clip_distance
        param_named stylizeEnabled float 1.0
        param_named shadowsEnabled float 1.0
        param_named highlightsEnabled float 1.0
        param_named shadowStrength float 0.4
        param_named highlightStrength float 0.1
        param_named shadowColor float3 0.0 0.0 0.0
        param_named highlightColor float3 1.0 1.0 1.0
    }
}
