PROJECT_NAME           = "PSX Dungeon Crawler"
PROJECT_BRIEF          = "C++17 PSX-style dungeon crawler engine and game API"
PROJECT_NUMBER         = "0.1"

OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIRECTORY@"
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

INPUT                  = "@CMAKE_CURRENT_SOURCE_DIR@/README.md" \
                         "@CMAKE_CURRENT_SOURCE_DIR@/docs/mainpage.md" \
                         "@CMAKE_CURRENT_SOURCE_DIR@/engine/include" \
                         "@CMAKE_CURRENT_SOURCE_DIR@/game/src" \
                         "@CMAKE_CURRENT_SOURCE_DIR@/samples/common"
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hpp *.cpp *.md
EXCLUDE_PATTERNS       = */build/* */build-*/* */vendor/* */third_party/* \
                         */_deps/*
USE_MDFILE_AS_MAINPAGE = "@CMAKE_CURRENT_SOURCE_DIR@/docs/mainpage.md"

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES
DISABLE_INDEX          = NO
GENERATE_LATEX         = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
HAVE_DOT               = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO
WARN_LOGFILE           = "@DOXYGEN_OUTPUT_DIRECTORY@/warnings.log"

QUIET                  = YES
GENERATE_XML           = NO
