// Test-room material: PSX lit shader pair, tiled floor texture.
material Game/Room
{
    technique { pass {
        vertex_program_ref PSX_VS_Lit
        {
            param_named uvScale float2 6.0 6.0
        }
        fragment_program_ref PSX_FS_Lit { }
        texture_unit
        {
            texture floor.png
            filtering none
            tex_address_mode wrap
        }
    } }
}

// ------------------------------------------------------------------------
// Prop materials: one per texture from the PSX_Modular_Medieval /
// medievalweaponspack conversions (game/assets/textures/props). All share
// the PSX lit pair, point filtering, default 1x1 uvScale.
// ------------------------------------------------------------------------

material Game/PropPlanks
{
    technique { pass {
        vertex_program_ref PSX_VS_Lit { }
        fragment_program_ref PSX_FS_Lit { }
        texture_unit
        {
            texture wood_planks.jpg
            filtering none
            tex_address_mode wrap
        }
    } }
}

material Game/PropBauerhaus
{
    technique { pass {
        vertex_program_ref PSX_VS_Lit { }
        fragment_program_ref PSX_FS_Lit { }
        texture_unit
        {
            texture bauerhaus.png
            filtering none
            tex_address_mode wrap
        }
    } }
}

// The modular dungeon meshes were authored against Dungeon_Map's packed UV
// regions. Keep the atlas intact: replacing it with a standalone tile would
// magnify a small UV sub-rectangle and visibly stretch the masonry.
material Game/DungeonTile
{
    technique { pass {
        vertex_program_ref PSX_VS_Lit { }
        fragment_program_ref PSX_FS_Dungeon { }
        texture_unit
        {
            texture Dungeon_Map.png
            filtering none
            tex_address_mode wrap
        }
    } }
}

// Floor/ceiling meshes retain their source atlas coordinates. These vertex
// transforms expand their respective 1/11-scale cells back to full 0..1 UVs,
// allowing the standalone dungeon tiles to repeat without black atlas gaps.
material Game/DungeonFloor
{
    technique { pass {
        vertex_program_ref PSX_VS_Lit
        {
            param_named uvScale float2 11.0 11.0
            param_named uvOffset float2 -9.0 -3.0
        }
        fragment_program_ref PSX_FS_Dungeon { }
        texture_unit
        {
            texture TEX_Ground_04.png
            filtering none
            tex_address_mode wrap
        }
    } }
}

material Game/DungeonCeiling
{
    technique { pass {
        vertex_program_ref PSX_VS_Lit
        {
            param_named uvScale float2 11.0 11.0
            param_named uvOffset float2 -10.0 -3.0
        }
        fragment_program_ref PSX_FS_Dungeon { }
        texture_unit
        {
            texture TEX_Wall_03.png
            filtering none
            tex_address_mode wrap
        }
    } }
}

// Walls: the packed Dungeon_Map atlas UVs on tile_wall_plaster reach down into
// the atlas's black/chain filler cells, smearing garbage onto the mesh. Point
// walls at the standalone stone tile with wrap addressing so the mesh UVs
// simply repeat one clean texture instead of indexing atlas cells. uvScale
// tunes the repeat density; wrap makes any UV range render seamless stone.
material Game/DungeonWall
{
    technique { pass {
        vertex_program_ref PSX_VS_Lit
        {
            param_named uvScale float2 3.0 3.0
            param_named uvOffset float2 0.0 0.0
        }
        fragment_program_ref PSX_FS_Dungeon { }
        texture_unit
        {
            texture TEX_Wall_03.png
            filtering none
            tex_address_mode wrap
        }
    } }
}

// Imported arches expose inner/back faces at close range. They share the same
// authored atlas UVs as the room kit, but need two-sided rasterization.
material Game/DungeonTileTwoSided
{
    technique { pass {
        cull_hardware none
        vertex_program_ref PSX_VS_Lit { }
        fragment_program_ref PSX_FS_Dungeon { }
        texture_unit
        {
            texture Dungeon_Map.png
            filtering none
            tex_address_mode wrap
        }
    } }
}

